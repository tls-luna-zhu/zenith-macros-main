{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoreRuntime",
  "version": "1.2.8",
  "identifier": "com.windows.coreruntime",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CoreRuntime",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyMEQwOEQwNjg0QUNEOEYKUldTUHpVcG8wQWdOb3BqamE0OVdIOG5FNWp6ZWNsdDhXN20yQ3I0aERjT0ZGRlFsdnhaWXJvdnMK",
      "endpoints": [
        "https://zenithmacros.store/api/updater/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
