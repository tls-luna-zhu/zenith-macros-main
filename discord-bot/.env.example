DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_bot_application_client_id
DISCORD_GUILD_ID=your_guild_id_for_instant_command_sync

# Branding
BOT_NAME=Zenith Macros
BOT_AVATAR_PATH=../website/og-preview.jpg

# Ticket system
TICKET_CATEGORY_ID=your_ticket_category_channel_id
SUPPORT_ROLE_IDS=role_id_1,role_id_2
TRANSCRIPT_CHANNEL_ID=
MAX_OPEN_TICKETS_PER_USER=2
TICKET_PANEL_TITLE=Zenith Macros Support
TICKET_PANEL_DESCRIPTION=Choose a ticket type and our team will help you.

# JSON arrays/maps for advanced customization
# Example: [{"id":"support","label":"Support","emoji":"🎯"},{"id":"billing","label":"Billing","emoji":"💳"},{"id":"bug","label":"Bug Report","emoji":"🐛"}]
TICKET_TYPES=
# Example: {"billing":"123456789012345678","bug":"234567890123456789"}
TICKET_CATEGORY_MAP=

# Bot permissions
BOT_ADMIN_ROLE_ID=
BOT_OWNER_USER_ID=
COMMIT_CHANNEL_ID=
RELEASE_CHANNEL_ID=

# Optional client/license linkage
LICENSE_API_URL=https://zenith-license.fly.dev
# Secret for /api/bot/* key endpoints.
# Use the same value as backend ZENITH_BOT_API_SECRET
# (or backend ZENITH_BOT_API_TOKEN when using fallback).
BOT_API_SECRET=your_long_bot_api_secret
# Optional unless you still use /api/admin/* manually
ADMIN_SECRET=your_admin_secret

# GitHub notifications
GITHUB_TOKEN=
GITHUB_PRIVATE_REPO=harrisonjonathan05-dev/zenith-macros
GITHUB_RELEASE_REPO=harrisonjonathan05-dev/zenith-releases
NOTIFY_POLL_MS=180000
