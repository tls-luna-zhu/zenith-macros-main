# Copy to .env and fill in real values. Never commit .env.

# --- Required for Flask startup (config.validate) ---
# Min 32 chars; used to sign Flask sessions (Discord web OAuth cookie).
ZENITH_SECRET_KEY=replace_with_at_least_32_random_characters

# Min 24 chars each; used by existing bot/store APIs.
ZENITH_BOT_API_TOKEN=replace_with_strong_token_min_24_chars
ZENITH_STORE_API_TOKEN=replace_with_strong_token_min_24_chars

# Optional; defaults to ZENITH_BOT_API_TOKEN if unset.
# ZENITH_BOT_API_SECRET=

# --- Marketing site: Discord OAuth (optional; /oauth routes 503 if client id missing) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Where users return after Discord authorizes (no trailing slash).
WEB_FRONTEND_ORIGIN=http://127.0.0.1:8080

# Must match a redirect URL in Discord Developer Portal → OAuth2 → Redirects.
WEB_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/oauth/discord/callback

# Comma-separated browser origins allowed to call /api/web/* with credentials.
WEB_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# --- Session cookie (HTTPS production) ---
# Leave unset or false for http:// local dev.
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=Lax

# --- Database (optional) ---
# ZENITH_DB_PATH=C:\path\to\zenith_licenses.db
